function vowel(s)
{
  let count=0;
  let vowels='aeiouAEIOU';
  
  for(let ch of s)
  {
    if( vowels.includes(ch))
    {
      count++;
    }
    
  }
  return count;
}
console.log("Find vowels counts");
var s="javascript";
console.log("Number of vowels in "+s+" is "+vowel(s));
console.log("--------------------------");


function maxarr(arr)
{
  max1=arr[0];
  
  for(let i=1;i<arr.length;i++)
  {
    if(arr[i]> max1)
    {
      max1=arr[i];
    }
  }
  return max1;
}
let arr=[2,10,8,11,45,3];
console.log("Find Maximum in the array ");
console.log("The maximum number in the array  ["+arr+"] is "+maxarr(arr));
