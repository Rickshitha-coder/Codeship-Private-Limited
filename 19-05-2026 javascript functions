function calculator(r, s1, op) {
  if (op == "+") return r + s1;
  if (op == "-") return r - s1;
  if (op == "*") return r * s1;
  if (op == "/") return r / s1;

  return "Invalid operator";
}
let r=20;
let s1=30;

console.log("Simple Calculator");
console.log("The Given Number "+r +" and "+s1+" is "+ calculator(r,s1, "+"));
console.log("The Given Number "+r +" and "+s1+" is "+ calculator(r,s1, "*"));
