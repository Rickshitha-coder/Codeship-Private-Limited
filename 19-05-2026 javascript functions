function isprime(n)
{
  if(n <= 1)
  {
    return n+ "is Not prime";
  }
  for(let i=2;i<n;i++)
  {
    if(n%i==0)
    {
      return n+ " is Not prime ";
    }
    
  }
  return n+" is prime";
}
console.log("Find prime Numbers");
console.log(isprime(5));
console.log(isprime(15));
console.log("---------------------------------");


function fibo(n)
{
  let a=0,b=1;
  
  for(let i=1;i<=n;i++)
  {
    console.log(a);
    let next=a+b;
    a=b;
    b=next;
  }

}
